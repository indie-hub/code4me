{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep|mcp__plugin_context-mode_context-mode__ctx_execute|mcp__plugin_context-mode_context-mode__ctx_execute_file|mcp__plugin_context-mode_context-mode__ctx_batch_execute",
        "hooks": [
        { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/check-structural-first-on-source.sh" }
      ]
    }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/check-session-wiring.sh" }
        ]
      }
    ]
  }
}
