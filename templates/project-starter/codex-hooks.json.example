{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash <PLUGIN_DIR>/hooks/check-test-protection.sh"
          },
          {
            "type": "command",
            "command": "bash <PLUGIN_DIR>/hooks/check-forbidden-conditions.sh"
          },
          {
            "type": "command",
            "command": "bash <PLUGIN_DIR>/hooks/check-critical-write-allowlist.sh"
          }
        ]
      },
      {
        "matcher": "Bash|mcp__plugin_context-mode_context-mode__ctx_execute|mcp__plugin_context-mode_context-mode__ctx_execute_file|mcp__plugin_context-mode_context-mode__ctx_batch_execute|mcp__context_mode__ctx_execute|mcp__context_mode__ctx_execute_file|mcp__context_mode__ctx_batch_execute",
        "hooks": [
          {
            "type": "command",
            "command": "bash <PLUGIN_DIR>/hooks/check-structural-first-on-source.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash <PLUGIN_DIR>/hooks/check-session-wiring.sh"
          }
        ]
      }
    ]
  }
}
