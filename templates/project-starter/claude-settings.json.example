{
  "_destination": "Copy this file to your project's .claude/settings.json. Replace <PLUGIN_DIR> with this plugin's absolute path, or run bin/code4me-install to wire it automatically.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash <PLUGIN_DIR>/hooks/check-test-protection.sh"
          },
          {
            "type": "command",
            "command": "bash <PLUGIN_DIR>/hooks/check-forbidden-conditions.sh"
          },
          {
            "type": "command",
            "command": "bash <PLUGIN_DIR>/hooks/check-critical-write-allowlist.sh"
          }
        ]
      },
      {
        "matcher": "Read|Grep|mcp__plugin_context-mode_context-mode__ctx_execute|mcp__plugin_context-mode_context-mode__ctx_execute_file|mcp__plugin_context-mode_context-mode__ctx_batch_execute",
        "hooks": [
          {
            "type": "command",
            "command": "bash <PLUGIN_DIR>/hooks/check-structural-first-on-source.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash <PLUGIN_DIR>/hooks/check-session-wiring.sh"
          }
        ]
      }
    ]
  },
  "_notes": {
    "recommended_install": "Prefer bin/code4me-install instead of manual path substitution. It writes machine-local hook paths and removes stale code4me hook entries.",
    "write_hooks": "check-test-protection, check-forbidden-conditions, and check-critical-write-allowlist gate Edit/Write/MultiEdit and return permissionDecision: ask when their .code4me/ state files are present.",
    "structural_first_hook": "check-structural-first-on-source.sh ask-gates source-code Read/Grep/context-mode lookups when codegraph, CocoIndex, or legacy LSP is available. Use codegraph first, CocoIndex second, legacy LSP only when configured, then Read/Grep/context-mode.",
    "session_start_hook": "check-session-wiring.sh is read-only. It nudges when copied hook paths or .lsp.json paths cannot resolve on the current machine.",
    "memory": "Use Basic Memory through MCP for durable project memory. See docs/howto-use-basic-memory.md.",
    "lsp": "LSP is legacy optional. Standard installs no longer set ENABLE_LSP_TOOL or generate .lsp.json unless bin/code4me-install --with-lsp is used."
  }
}
